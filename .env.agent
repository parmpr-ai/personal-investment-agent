# ─── Agent Service Configuration ───────────────────────────────────────────

# Service
AGENT_SERVICE_HOST=0.0.0.0
AGENT_SERVICE_PORT=8001
LOG_LEVEL=info

# Training defaults
AGENT_DEFAULT_TICKERS=NVDA,MSFT,AAPL,TSLA,AMD,GOOGL,META,AMZN,NFLX,CRM,ADBE,INTC,AVGO,MAGI
AGENT_USE_CACHE=true
AGENT_REFRESH=false
AGENT_PARALLEL=true
AGENT_INCREMENTAL=false
AGENT_FEATURE_SELECTION=true

# Model persistence
AGENT_MODELS_DIR=./models
AGENT_CACHE_DB=./ml_data_cache.sqlite3
AGENT_TRAINING_DB=./agent_training.sqlite3

# Backtest settings
AGENT_BACKTEST_DAYS=504
AGENT_BACKTEST_SAVE_RESULTS=true

# Monitoring
AGENT_METRICS_ENABLED=true
AGENT_LOG_TRAINING_DETAILS=true
