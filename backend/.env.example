# Developer fallback only. V5.6 stores most integration settings in the app UI / SQLite.
IBKR_ENABLED=true
IBKR_HOST=127.0.0.1
IBKR_PORT=4001
IBKR_CLIENT_ID=21
IBKR_MODE=live

# Autonomous Agent — rule-based engine, zero API cost, no API key needed
# Agent execution modes: paper (internal) | ibkr_paper (IBKR paper account) | live (IBKR live)
IBKR_PAPER_PORT=4002          # IB Gateway paper port (TWS paper = 7497)
IBKR_AGENT_CLIENT_ID=32       # separate client_id from read-only portfolio connection (31)
