# Personal Investment Agent Configuration
# Copy this to .env and fill in your values

# ============= API KEYS =============
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_key_here

# ============= INTERACTIVE BROKERS =============
# Paper trading account credentials
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password
IBKR_ACCOUNT=DU12345  # Paper trading account ID

# ============= TRADING CONFIG =============
# Portfolio size (paper trading)
INITIAL_CAPITAL=100000

# Risk management
MAX_POSITION_SIZE=0.05  # 5% of capital per trade
MAX_CONCURRENT_POSITIONS=25
STOP_LOSS_PCT=2
TAKE_PROFIT_PCT=3

# ============= AGENT CONFIG =============
# Enable/disable trading
AGENT_ENABLED=true
AGENT_MODE=paper  # 'paper' for paper trading only

# Cycle frequency (minutes)
AGENT_CYCLE_MINUTES=15

# ============= LOGGING =============
LOG_LEVEL=INFO
DEBUG=false

# ============= DATABASE =============
# SQLite database location (relative to backend/)
DATABASE_PATH=./autonomous_trades.sqlite3
CACHE_DB_PATH=./ml_data_cache.sqlite3

# ============= SCHEDULER =============
# Market hours (ET)
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=30
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=0

# Daily screening time (ET)
SCREENING_HOUR=16
SCREENING_MINUTE=15
