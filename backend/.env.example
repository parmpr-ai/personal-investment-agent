# Developer fallback only. V5.6 stores most integration settings in the app UI / SQLite.
IBKR_ENABLED=true
IBKR_HOST=127.0.0.1
IBKR_PORT=4001
IBKR_CLIENT_ID=21
IBKR_MODE=live

# Autonomous Agent — rule-based engine, zero API cost, no API key needed
# Agent execution modes: paper (internal) | ibkr_paper (IBKR paper account) | live (IBKR live)
IBKR_PAPER_PORT=4002          # IB Gateway paper port (TWS paper = 7497)
IBKR_AGENT_CLIENT_ID=32       # separate client_id from read-only portfolio connection (31)

# ── Optional: Free AI News Scoring (add ONE key to upgrade from keyword scoring) ──
# Priority: Groq → Cerebras → Gemini → Mistral → Finnhub → keyword fallback
# All are permanent free tiers, no credit card required at sign-up.

# Groq — https://console.groq.com (1,000 req/day free, llama-3.3-70b, fastest)
# GROQ_API_KEY=gsk_...

# Cerebras — https://cloud.cerebras.ai (1M tokens/day free, llama-3.3-70b, huge quota)
# CEREBRAS_API_KEY=csk-...

# Google Gemini — https://aistudio.google.com/apikey (1,500 req/day free)
# GEMINI_API_KEY=AIza...

# Mistral — https://console.mistral.ai (experimental free tier, phone required)
# MISTRAL_API_KEY=...

# Finnhub — https://finnhub.io/register (pre-scored sentiment, 60 RPM, no LLM tokens used)
# FINNHUB_API_KEY=...
