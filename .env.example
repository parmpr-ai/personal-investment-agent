# ── AI News Scoring (optional) ────────────────────────────────────────────────
# Get a free key at https://console.groq.com/keys
# If not set, falls back to keyword-only news scoring (no LLM)
GROQ_API_KEY=

# ── Finnhub (optional — free tier, news + fundamentals) ──────────────────────
# Get at https://finnhub.io
FINNHUB_API_KEY=

# ── IBKR Paper Trading (optional) ─────────────────────────────────────────────
# Only needed if mode = "ibkr_paper". Default paper trading uses internal SQLite book.
# TWS / IB Gateway must be running on localhost:7497
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
# Get a bot token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
