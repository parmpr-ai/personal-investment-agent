# ── AI News Scoring (optional) ────────────────────────────────────────────────
# Get a free key at https://console.groq.com/keys
# If not set, falls back to keyword-only news scoring (no LLM)
GROQ_API_KEY=

# ── Finnhub (optional — free tier, quotes + news + fundamentals) ─────────────
# Get at https://finnhub.io — also used as Yahoo Finance intraday fallback
FINNHUB_API_KEY=

# ── Alpha Vantage (optional — free tier, 25 req/day, daily OHLCV fallback) ───
# Get at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── IBKR Paper Trading (optional) ─────────────────────────────────────────────
# Only needed if mode = "ibkr_paper". Default paper trading uses internal SQLite book.
# TWS / IB Gateway must be running on localhost:7497
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
# Get a bot token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
